# Agent Handoff Manager - Environment Variables
# Copy this to .env and fill in your values

# Server Port
PORT=3458

# Agent Execution Mode
# Options: 'openclaw' (use CLI on VPS) or 'local_http' (call agents on your local device)
AGENT_MODE=local_http

# Local Agent Endpoint (when AGENT_MODE=local_http)
# Use ngrok or similar to expose your local agent API to the internet
# Example: https://your-ngrok-url.ngrok.io/agent
LOCAL_AGENT_ENDPOINT=http://localhost:3001/agent

# ChromaBase Configuration
# Get your userId from Firebase Auth
CHROMABASE_URL=http://127.0.0.1:3000
CHROMABASE_USER_ID=your_firebase_uid_here

# Discord Configuration
# Create a webhook in your Discord server: Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK/URL

# Agent-specific Discord channels (optional - sends to both general + agent channel)
DISCORD_CHANNEL_CHROMA=
DISCORD_CHANNEL_BENDER=
DISCORD_CHANNEL_PIXEL=
DISCORD_CHANNEL_CANVAS=
DISCORD_CHANNEL_FLUX=
DISCORD_CHANNEL_PRISM=
DISCORD_CHANNEL_LUMEN=
DISCORD_CHANNEL_MOMENTUM=
DISCORD_CHANNEL_GLYPH=
DISCORD_CHANNEL_CHIEF=
