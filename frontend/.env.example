# Frontend Environment Variables
# Copy to .env.local for local dev, or set in production

# API Base URL (HTTP)
NEXT_PUBLIC_API_URL=http://localhost:3461/api

# WebSocket URL
NEXT_PUBLIC_WS_URL=ws://localhost:3461

# For production, use your VPS domain:
# NEXT_PUBLIC_API_URL=https://team.chromapages.com/api
# NEXT_PUBLIC_WS_URL=wss://team.chromapages.com
