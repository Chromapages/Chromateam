# Agent Handoff Manager - Environment Variables
# Copy this to .env.local for local development

# HTTP API URL (no trailing slash, no /api suffix - the client adds it)
NEXT_PUBLIC_API_URL=https://ahm-rust.vercel.app

# WebSocket URL (wss for HTTPS, ws for HTTP)
NEXT_PUBLIC_WS_URL=wss://ahm-rust.vercel.app
